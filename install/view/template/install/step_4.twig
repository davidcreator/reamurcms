{{ header }}
<main id="content" role="main">
	<div class="page-header">
		<div class="container">
			<h1>{{ heading_title }}</h1>
		</div>
	</div>
	<div class="container">
		{% if error_warning %}
		<div class="alert alert-danger" role="alert"><i class="fa-solid fa-circle-exclamation" aria-hidden="true"></i> {{ error_warning }}</div>
		{% endif %}
		<div class="card">
			<div class="card-header"><i class="fa-solid fa-pencil" aria-hidden="true"></i> {{ text_step_4 }}</div>
			<div class="card-body p-4">
				<div class="row mb-4">
					<div class="col-md-6 col-sm-12 text-center mb-3 mb-md-0">
						<a href="../" aria-label="{{ text_catalog }}">
							<img src="view/image/catalog.jpg" alt="ReamurCMS Catalog" title="ReamurCMS Catalog" class="img-thumbnail"/>
						</a>
						<br/>
						<a href="../" class="btn btn-outline-secondary mt-3" role="button">{{ text_catalog }}</a>
					</div>
					<div class="col-md-6 col-sm-12 text-center">
						<a href="../admin/" aria-label="{{ text_admin }}">
							<img src="view/image/admin.jpg" alt="ReamurCMS Admin" title="ReamurCMS Admin" class="img-thumbnail"/>
						</a>
						<br/>
						<a href="../admin/" class="btn btn-outline-secondary mt-3" role="button">{{ text_admin }}</a>
					</div>
				</div>
				<div class="mb-4">{{ promotion }}</div>
				<div class="m-4 text-center">
					<a href="https://reamurcms.com/index.php?route=marketplace/extension&utm_source=reamurcms_install&utm_medium=store_link&utm_campaign=reamurcms_install" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary" role="button">{{ text_extension }}</a>
				</div>
				<fieldset class="mb-5">
					<legend><i class="fa-solid fa-envelope" aria-hidden="true"></i> {{ text_mail }}</legend>
					<div class="text-center">
						<p class="pb-2">{{ text_mail_description }}</p>
						<a href="http://newsletter.reamurcms.com/h/r/B660EBBE4980C85C" target="_blank" rel="noopener noreferrer" class="btn btn-primary" role="button"><i class="fa-solid fa-envelope" aria-hidden="true"></i> {{ button_mail }}</a>
					</div>
				</fieldset>
				<div class="row mb-4">
					<div class="col-lg-4 col-md-12 text-center mb-3 mb-lg-0">
						<h3><a href="https://www.facebook.com/reamurcms" target="_blank" rel="noopener noreferrer" class="icon transition"><i class="fab fa-facebook" aria-hidden="true"></i></a> {{ text_facebook }}</h3>
						<p>{{ text_facebook_description }}</p>
						<a href="https://www.facebook.com/reamurcms" target="_blank" rel="noopener noreferrer">{{ text_facebook_visit }}</a>
					</div>
					<div class="col-lg-4 col-md-12 text-center mb-3 mb-lg-0">
						<h3><a href="https://forum.reamurcms.com/?utm_source=reamurcms_install&utm_medium=forum_link&utm_campaign=reamurcms_install" target="_blank" rel="noopener noreferrer" class="icon transition"><i class="fa-solid fa-comments" aria-hidden="true"></i></a> {{ text_forum }}</h3>
						<p>{{ text_forum_description }}</p>
						<a href="https://forum.reamurcms.com/?utm_source=reamurcms_install&utm_medium=forum_link&utm_campaign=reamurcms_install" target="_blank" rel="noopener noreferrer">{{ text_forum_visit }}</a>
					</div>
					<div class="col-lg-4 col-md-12 text-center">
						<h3><a href="https://reamurcms.com/index.php?route=support/partner&utm_source=reamurcms_install&utm_medium=partner_link&utm_campaign=reamurcms_install" target="_blank" rel="noopener noreferrer" class="icon transition"><i class="fa-solid fa-user" aria-hidden="true"></i></a> {{ text_commercial }}</h3>
						<p>{{ text_commercial_description }}</p>
						<a href="https://reamurcms.com/index.php?route=support/partner&utm_source=reamurcms_install&utm_medium=partner_link&utm_campaign=reamurcms_install" target="_blank" rel="noopener noreferrer">{{ text_commercial_visit }}</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</main>
{{ footer }}
