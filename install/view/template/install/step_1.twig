{{ header }}
<main id="content" role="main">
	<div class="page-header">
		<div class="container">
			<div class="float-end">{{ language }}</div>
			<h1>{{ heading_title }}</h1>
		</div>
	</div>
	<div class="container">
		<div class="card">
			<div class="card-header">
				<i class="fab fa-reamurcms" aria-hidden="true"></i>
				<span class="ms-2">{{ text_step_1 }}</span>
			</div>
			<div class="card-body">
				<div class="form-control overflow-auto" style="max-height: 300px;" tabindex="0" aria-label="{{ text_step_1 }}">
					{{ text_terms }}
				</div>
				<div class="row mt-3">
					<div class="col text-end">
						<a href="{{ continue }}" class="btn btn-primary" role="button">{{ button_continue }}</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</main>
{{ footer }}