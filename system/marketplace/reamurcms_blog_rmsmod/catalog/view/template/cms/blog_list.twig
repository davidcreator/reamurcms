{{ header }}
<div id="content" class="container">
  <div class="row">
    {{ column_left }}
    {% if column_left and column_right %}
      {% set class = 'col-sm-6' %}
    {% elseif column_left or column_right %}
      {% set class = 'col-sm-9' %}
    {% else %}
      {% set class = 'col-sm-9' %}
    {% endif %}
    <div id="blog-list" class="{{ class }}">
      {% if breadcrumbs %}
        <ul class="breadcrumb">
          {% for breadcrumb in breadcrumbs %}
            <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
          {% endfor %}
        </ul>
      {% endif %}

      <h1 class="heading-title">{{ heading_title }}</h1>

      <div class="panel panel-default">
        <div class="panel-body">
          <form class="form-horizontal" method="get" action="{{ link_blog }}">
            <div class="row">
              <div class="col-sm-5">
                <div class="form-group">
                  <label class="control-label" for="blog-search">{{ entry_search }}</label>
                  <input id="blog-search" type="text" name="q" value="{{ filter_search }}" class="form-control" placeholder="{{ entry_search }}">
                </div>
              </div>
              <div class="col-sm-4">
                <div class="form-group">
                  <label class="control-label" for="blog-category">{{ text_categories }}</label>
                  <select id="blog-category" name="category_id" class="form-control">
                    <option value="0">--</option>
                    {% for cat in categories %}
                      <option value="{{ cat.category_id }}" {% if filter_category_id == cat.category_id %}selected{% endif %}>{{ cat.name }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>
              <div class="col-sm-3">
                <div class="form-group">
                  <label class="control-label" for="blog-tag">{{ text_tags }}</label>
                  <input id="blog-tag" type="text" name="tag" value="{{ filter_tag }}" class="form-control" placeholder="#tag">
                </div>
              </div>
            </div>
            <div class="form-group">
              <button class="btn btn-primary" type="submit">{{ button_filter }}</button>
              <a class="btn btn-default" href="{{ link_blog }}">{{ text_filters_reset }}</a>
            </div>
          </form>
        </div>
      </div>

      {% if posts %}
        <div class="row">
          {% for post in posts %}
            <div class="product-layout product-grid col-lg-4 col-md-4 col-sm-6 col-xs-12">
              <div class="product-thumb transition">
                {% if post.featured_image %}
                  <div class="image">
                    <a href="{{ post.href }}"><img src="{{ post.featured_image }}" alt="{{ post.title }}" title="{{ post.title }}" class="img-responsive" loading="lazy" /></a>
                  </div>
                {% endif %}
                <div class="caption">
                  <h4><a href="{{ post.href }}">{{ post.title }}</a>{% if post.is_featured %} <span class="label label-primary">{{ text_featured }}</span>{% endif %}</h4>
                  <p class="small text-muted">
                    {% if post.published_at %}{{ text_published_on }} {{ post.published_at }}{% endif %}
                    {% if post.reading_time %} &bull; {{ text_read_time }} {{ post.reading_time }} {{ text_minutes }}{% endif %}
                  </p>
                  {% if post.excerpt %}
                    <p>{{ post.excerpt }}</p>
                  {% endif %}
                  {% if post.categories %}
                    <p class="small">
                      {% for cat in post.categories %}
                        <a class="label label-default" href="{{ cat.href }}">{{ cat.name }}</a>
                      {% endfor %}
                    </p>
                  {% endif %}
                  {% if post.tags_list %}
                    <p class="small">
                      {% for tag in post.tags_list %}
                        <a class="label label-info" href="{{ link_tag_base ~ '&tag=' ~ tag|url_encode }}">#{{ tag }}</a>
                      {% endfor %}
                    </p>
                  {% endif %}
                </div>
                <div class="button-group">
                  <a href="{{ post.href }}" class="btn btn-default btn-block">{{ text_read_more }}</a>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
        <div class="row">
          <div class="col-sm-6 text-left">{{ pagination }}</div>
          <div class="col-sm-6 text-right"></div>
        </div>
      {% else %}
        <p>{{ text_no_results }}</p>
      {% endif %}
    </div>

    <div class="col-sm-3 col-md-3">
      <div class="list-group">
        <a class="list-group-item active">{{ text_categories }}</a>
        {% for cat in categories %}
          <a class="list-group-item {% if filter_category_id == cat.category_id %}active{% endif %}" href="{{ cat.href }}">{{ cat.name }}</a>
        {% else %}
          <span class="list-group-item text-muted">{{ text_no_results }}</span>
        {% endfor %}
      </div>

      <div class="panel panel-default">
        <div class="panel-heading">{{ text_tags }}</div>
        <div class="panel-body">
          {% for tag in tags %}
            <a class="label label-info" style="display:inline-block;margin-bottom:4px;" href="{{ tag.href }}">#{{ tag.name }}</a>
          {% else %}
            <span class="text-muted small">{{ text_no_results }}</span>
          {% endfor %}
        </div>
      </div>

      <div class="panel panel-default">
        <div class="panel-heading">{{ text_latest_posts }}</div>
        <ul class="list-group">
          {% for item in latest_posts %}
            <li class="list-group-item"><a href="{{ item.href }}">{{ item.title }}</a></li>
          {% else %}
            <li class="list-group-item text-muted small">{{ text_no_results }}</li>
          {% endfor %}
        </ul>
      </div>

      <div class="panel panel-default">
        <div class="panel-heading">{{ text_top_posts }}</div>
        <ul class="list-group">
          {% for item in top_posts %}
            <li class="list-group-item">
              <a href="{{ item.href }}">{{ item.title }}</a>
              {% if item.views %}<span class="badge">{{ item.views }}</span>{% endif %}
            </li>
          {% else %}
            <li class="list-group-item text-muted small">{{ text_no_results }}</li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</div>
{{ footer }}
