{{ header }}
{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-post" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
        <a href="{{ cancel }}" class="btn btn-default"><i class="fa fa-reply"></i> {{ button_cancel }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if errors.warning %}
      <div class="alert alert-danger">{{ errors.warning }}</div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading"><h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_form }}</h3></div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-post" class="form-horizontal">
          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-title">{{ entry_title }}</label>
            <div class="col-sm-10">
              <input type="text" name="title" value="{{ post.title }}" id="input-title" class="form-control" />
              {% if errors.title %}<div class="text-danger">{{ errors.title }}</div>{% endif %}
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-slug">{{ entry_slug }}</label>
            <div class="col-sm-10">
              <input type="text" name="slug" value="{{ post.slug }}" id="input-slug" class="form-control" />
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="status" id="input-status" class="form-control">
                <option value="draft" {{ post.status == 'draft' ? 'selected' : '' }}>{{ text_draft }}</option>
                <option value="published" {{ post.status == 'published' ? 'selected' : '' }}>{{ text_published }}</option>
                <option value="pending" {{ post.status == 'pending' ? 'selected' : '' }}>{{ text_pending }}</option>
                <option value="private" {{ post.status == 'private' ? 'selected' : '' }}>{{ text_private }}</option>
                <option value="archived" {{ post.status == 'archived' ? 'selected' : '' }}>{{ text_archived }}</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-excerpt">{{ entry_excerpt }}</label>
            <div class="col-sm-10">
              <textarea name="excerpt" id="input-excerpt" rows="3" class="form-control">{{ post.excerpt }}</textarea>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-featured-image">{{ entry_featured_image }}</label>
            <div class="col-sm-10">
              <input type="text" name="featured_image" value="{{ post.featured_image }}" id="input-featured-image" class="form-control" placeholder="https://...">
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-og-image">{{ entry_og_image }}</label>
            <div class="col-sm-10">
              <input type="text" name="og_image" value="{{ post.og_image }}" id="input-og-image" class="form-control" placeholder="https://...">
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-tags">{{ entry_tags }}</label>
            <div class="col-sm-10">
              <input type="text" name="tags" value="{{ post.tags }}" id="input-tags" class="form-control" placeholder="seo, performance, headless">
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-published-at">{{ entry_published_at }}</label>
            <div class="col-sm-4">
              <input type="datetime-local" name="published_at" value="{{ post.published_at ? post.published_at|date('Y-m-d\\TH:i') : '' }}" id="input-published-at" class="form-control">
            </div>
            <label class="col-sm-2 control-label" for="input-is-featured">{{ entry_is_featured }}</label>
            <div class="col-sm-4">
              <input type="checkbox" name="is_featured" id="input-is-featured" value="1" {{ post.is_featured ? 'checked' : '' }}>
              <span class="help-block">{{ text_featured }}</span>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-content">{{ entry_content }}</label>
            <div class="col-sm-10">
              <textarea name="content" id="input-content" rows="12" class="form-control">{{ post.content }}</textarea>
            </div>
          </div>
          <hr>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-meta-title">{{ entry_meta_title }}</label>
            <div class="col-sm-10">
              <input type="text" name="meta_title" value="{{ post.meta_title }}" id="input-meta-title" class="form-control" maxlength="255">
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-meta-description">{{ entry_meta_description }}</label>
            <div class="col-sm-10">
              <textarea name="meta_description" id="input-meta-description" rows="2" class="form-control" maxlength="180">{{ post.meta_description }}</textarea>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-meta-keywords">{{ entry_meta_keywords }}</label>
            <div class="col-sm-10">
              <input type="text" name="meta_keywords" value="{{ post.meta_keywords }}" id="input-meta-keywords" class="form-control" placeholder="headless, blog, cms">
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-canonical">{{ entry_canonical_url }}</label>
            <div class="col-sm-10">
              <input type="text" name="canonical_url" value="{{ post.canonical_url }}" id="input-canonical" class="form-control" placeholder="https://site.com/blog/slug">
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-schema">{{ entry_schema_json }}</label>
            <div class="col-sm-10">
              <textarea name="schema_json" id="input-schema" rows="4" class="form-control" placeholder='{\"@context\":\"https://schema.org\",\"@type\":\"Article\"...}'>{{ post.schema_json }}</textarea>
              <p class="help-block">Se vazio, o schema automÃ¡tico serÃ¡ usado.</p>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label">Tempo de leitura</label>
            <div class="col-sm-10">
              <input type="text" readonly class="form-control-plaintext" value="{{ post.reading_time ? post.reading_time ~ ' min' : 'Calculado automaticamente' }}">
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
