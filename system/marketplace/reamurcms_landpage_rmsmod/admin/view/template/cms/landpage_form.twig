{{ header }}
{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-page" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
        <a href="{{ cancel }}" class="btn btn-default"><i class="fa fa-reply"></i> {{ button_cancel }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if errors.warning %}<div class="alert alert-danger">{{ errors.warning }}</div>{% endif %}
    <div class="panel panel-default">
      <div class="panel-heading"><h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_form }}</h3></div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-page" class="form-horizontal">
          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-title">{{ entry_title }}</label>
            <div class="col-sm-10">
              <input type="text" name="title" value="{{ page.title }}" id="input-title" class="form-control" />
              {% if errors.title %}<div class="text-danger">{{ errors.title }}</div>{% endif %}
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-slug">{{ entry_slug }}</label>
            <div class="col-sm-10">
              <input type="text" name="slug" value="{{ page.slug }}" id="input-slug" class="form-control" />
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="status" id="input-status" class="form-control">
                <option value="draft" {{ page.status == 'draft' ? 'selected' : '' }}>{{ text_draft }}</option>
                <option value="published" {{ page.status == 'published' ? 'selected' : '' }}>{{ text_published }}</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-template">{{ entry_template }}</label>
            <div class="col-sm-10">
              <select name="template" id="input-template" class="form-control">
                <option value="default" {{ page.template == 'default' ? 'selected' : '' }}>{{ text_template_default }}</option>
                <option value="hero" {{ page.template == 'hero' ? 'selected' : '' }}>{{ text_template_hero }}</option>
                <option value="split" {{ page.template == 'split' ? 'selected' : '' }}>{{ text_template_split }}</option>
                <option value="lead" {{ page.template == 'lead' ? 'selected' : '' }}>{{ text_template_lead }}</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-featured">{{ entry_featured_image }}</label>
            <div class="col-sm-10">
              <div class="d-flex gap-3 align-items-center">
                <a href="" id="thumb-image" data-rms-toggle="image" data-rms-target="#input-image" data-rms-thumb="#thumb-image" class="img-thumbnail">
                  <img src="{{ thumb }}" alt="" title="" data-placeholder="{{ placeholder }}" />
                </a>
                <div class="btn-group-vertical" role="group">
                  <button type="button" data-rms-toggle="image" data-rms-target="#input-image" data-rms-thumb="#thumb-image" class="btn btn-primary btn-sm"><i class="fa-solid fa-pencil"></i> {{ button_edit }}</button>
                  <button type="button" data-rms-toggle="clear" data-rms-target="#input-image" data-rms-thumb="#thumb-image" class="btn btn-warning btn-sm"><i class="fa-regular fa-trash-can"></i> {{ button_clear }}</button>
                </div>
              </div>
              <input type="hidden" name="featured_image" value="{{ page.featured_image }}" id="input-image"/>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-html">{{ entry_html }}</label>
            <div class="col-sm-10">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div>
                  <span class="fw-bold">{{ text_snippet }}</span>
                  <small class="text-muted d-block">{{ text_snippet_help }}</small>
                </div>
                <div class="d-flex gap-2">
                  <select id="snippet-select" class="form-control input-sm">
                    <option value="hero">Hero</option>
                    <option value="features">Features</option>
                    <option value="cta">CTA</option>
                    <option value="form">Form</option>
                  </select>
                  <button type="button" id="btn-insert-snippet" class="btn btn-outline-primary btn-sm">{{ button_insert_snippet }}</button>
                </div>
              </div>
              <textarea name="html" id="input-html" rows="15" data-rms-toggle="ckeditor" data-lang="{{ ckeditor }}" class="form-control">{{ page.html }}</textarea>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-published">{{ entry_published_at }}</label>
            <div class="col-sm-10">
              <input type="datetime-local" name="published_at" value="{{ page.published_at }}" id="input-published" class="form-control"/>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-meta-title">{{ entry_meta_title }}</label>
            <div class="col-sm-10">
              <input type="text" name="meta_title" value="{{ page.meta_title }}" id="input-meta-title" class="form-control"/>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-meta-description">{{ entry_meta_description }}</label>
            <div class="col-sm-10">
              <textarea name="meta_description" id="input-meta-description" rows="3" class="form-control">{{ page.meta_description }}</textarea>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-meta-keyword">{{ entry_meta_keyword }}</label>
            <div class="col-sm-10">
              <input type="text" name="meta_keyword" value="{{ page.meta_keyword }}" id="input-meta-keyword" class="form-control"/>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-custom-css">{{ entry_custom_css }}</label>
            <div class="col-sm-10">
              <textarea name="custom_css" id="input-custom-css" rows="4" class="form-control" placeholder="/* CSS da página */">{{ page.custom_css }}</textarea>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript">
  const snippets = {{ snippets|json_encode(constant('JSON_UNESCAPED_SLASHES')) }};
  $('#btn-insert-snippet').on('click', function () {
    const key = $('#snippet-select').val();
    const html = snippets[key] || '';
    const editor = $('#input-html');
    if (editor.data('ckeditorInstance')) {
      editor.data('ckeditorInstance').insertHtml(html);
    } else {
      editor.val(editor.val() + '\\n\\n' + html);
    }
  });
  $('textarea[data-rms-toggle=\\'ckeditor\\']').each(function(){ $(this).ckeditor({language:'{{ ckeditor }}'}); });
</script>
{{ footer }}
