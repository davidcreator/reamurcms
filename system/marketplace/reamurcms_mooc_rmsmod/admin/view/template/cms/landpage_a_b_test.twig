{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-variant" formaction="{{ delete }}" class="btn btn-danger" onclick="return confirm('{{ text_confirm }}');"><i class="fa fa-trash"></i> {{ button_delete }}</button>
        <a href="{{ add }}" class="btn btn-primary"><i class="fa fa-plus"></i> {{ text_add }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-random"></i> {{ heading_title }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-variant">
          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead>
                <tr>
                  <th style="width:1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\\'selected\\']').prop('checked', this.checked);" /></th>
                  <th>{{ column_page }}</th>
                  <th>{{ column_variant }}</th>
                  <th class="text-right">{{ column_weight }}</th>
                  <th>{{ column_status }}</th>
                  <th class="text-right">{{ column_action }}</th>
                </tr>
              </thead>
              <tbody>
                {% if variants %}
                  {% for variant in variants %}
                    <tr>
                      <td class="text-center"><input type="checkbox" name="selected[]" value="{{ variant.variant_id }}" /></td>
                      <td>{{ variant.page_title }}</td>
                      <td>{{ variant.name }}</td>
                      <td class="text-right">{{ variant.weight }}%</td>
                      <td>{% if variant.status %}{{ text_variant_active }}{% else %}{{ text_variant_disabled }}{% endif %}</td>
                      <td class="text-right"><a href="{{ variant.edit }}" class="btn btn-primary btn-sm"><i class="fa fa-pencil"></i></a></td>
                    </tr>
                  {% endfor %}
                {% else %}
                  <tr>
                    <td class="text-center" colspan="6">{{ text_no_results }}</td>
                  </tr>
                {% endif %}
              </tbody>
            </table>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
