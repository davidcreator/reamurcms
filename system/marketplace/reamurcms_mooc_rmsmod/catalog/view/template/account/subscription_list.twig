<div class="subscription">
  <h1>{{ heading_title }}</h1>
  {% if active %}
    <div class="alert alert-success">{{ text_active_until }} {{ active.end_date }}</div>
  {% endif %}

  {% if plans %}
    <form method="post" action="{{ action }}" class="card p-3">
      <h3>{{ text_choose_plan }}</h3>
      <div class="mb-3">
        {% for p in plans %}
          <div class="form-check mb-2">
            <input class="form-check-input" type="radio" name="plan_id" id="plan_{{ p.plan_id }}" value="{{ p.plan_id }}" {% if loop.first %}checked{% endif %}>
            <label class="form-check-label" for="plan_{{ p.plan_id }}">
              <strong>{{ p.name }}</strong> - {{ text_price }} {{ p.price }} {{ p.currency }} / {{ p.period_days }}d
              {% if p.description %}<div class="small text-muted">{{ p.description }}</div>{% endif %}
            </label>
          </div>
        {% endfor %}
      </div>
      <div class="mb-3">
        <label class="form-label">Método</label>
        <select name="method" class="form-select">
          <option value="card">Cartão</option>
          <option value="pix">PIX</option>
          <option value="boleto">Boleto</option>
        </select>
      </div>
      <button type="submit" class="btn btn-primary">{{ text_subscribe }}</button>
    </form>
  {% else %}
    <p>{{ text_no_plans }}</p>
  {% endif %}
</div>
