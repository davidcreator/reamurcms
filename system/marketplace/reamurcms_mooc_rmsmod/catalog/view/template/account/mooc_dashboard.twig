<div class="dashboard">
  <h1>{{ heading_title }}</h1>

  <section class="profile card mb-3 p-3">
    <h3>{{ text_profile }}</h3>
    <p>{{ customer_name }}<br>{{ customer_email }}</p>
  </section>

  <section class="notifications card mb-3 p-3">
    <h3>{{ text_notifications }}</h3>
    {% if notifications %}
      <ul class="list-group">
        {% for n in notifications %}
          <li class="list-group-item d-flex justify-content-between align-items-start">
            <div>
              <strong>{{ n.title }}</strong>
              <div class="small text-muted">{{ n.created_at }}</div>
              <div>{{ n.message }}</div>
              {% if n.url %}<a href="{{ n.url }}" class="small">{{ text_view }}</a>{% endif %}
            </div>
            <a class="btn btn-sm btn-outline-secondary" href="{{ n.mark_href }}">{{ text_mark_read }}</a>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>{{ text_no_notifications }}</p>
    {% endif %}
  </section>

  <section class="gamification card mb-3 p-3">
    <h3>{{ text_badges }}</h3>
    <div class="row mb-3">
      <div class="col-md-4"><strong>{{ text_points }}</strong><br>{{ gamification.points }}</div>
      <div class="col-md-4"><strong>{{ text_streak }}</strong><br>{{ gamification.current_streak }} (máx {{ gamification.max_streak }})</div>
      <div class="col-md-4"><strong>{{ text_badges }}</strong><br>{{ gamification.badges|length }}</div>
    </div>
    {% if gamification.badges %}
      <ul class="list-group mb-3">
        {% for b in gamification.badges %}
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span>{{ b.name }}<br><small class="text-muted">{{ b.description }}</small></span>
            <span class="badge bg-success">{{ b.unlocked_at }}</span>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>{{ text_none }}</p>
    {% endif %}
  </section>

  <section class="leaderboard card mb-3 p-3">
    <h3>{{ text_leaderboard }}</h3>
    {% if leaderboard %}
      <ol class="mb-0">
        {% for u in leaderboard %}
          <li>{{ u.firstname }} {{ u.lastname }} - {{ u.points }} {{ text_points|lower }}</li>
        {% endfor %}
      </ol>
    {% else %}
      <p>{{ text_none }}</p>
    {% endif %}
  </section>

  <section class="goals card mb-3 p-3">
    <h3>{{ text_goals }}</h3>
    {% if goals %}
      <ul class="list-group">
        {% for g in goals %}
          <li class="list-group-item">
            <div class="d-flex justify-content-between"><strong>{{ g.title }}</strong><span>{{ g.progress }}/{{ g.target }}</span></div>
            <div class="progress mt-2" style="height:8px;">
              <div class="progress-bar" role="progressbar" style="width: {{ g.percent }}%"></div>
            </div>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>{{ text_none }}</p>
    {% endif %}
  </section>

  <section class="my-courses card mb-3 p-3">
    <h3>{{ text_my_courses }}</h3>
    {% if enrollments %}
      <ul class="list-group">
        {% for c in enrollments %}
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <div>
              <strong>{{ c.title }}</strong>
              <div class="small text-muted">{{ text_progress }}: {{ c.progress_percent }}%</div>
            </div>
            <a class="btn btn-sm btn-primary" href="{{ c.href }}">{{ text_view }}</a>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>{{ text_none }}</p>
    {% endif %}
  </section>

  <section class="recommended card mb-3 p-3">
    <h3>{{ text_recommended }}</h3>
    {% if recommended %}
      <ul class="list-group">
        {% for c in recommended %}
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <strong>{{ c.title }}</strong>
            <a class="btn btn-sm btn-outline-primary" href="{{ c.href }}">{{ text_view }}</a>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>{{ text_none }}</p>
    {% endif %}
  </section>

  <section class="certificates card mb-3 p-3">
    <h3>{{ text_certificates }}</h3>
    {% if certificates %}
      <ul class="list-group">
        {% for cert in certificates %}
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <div>
              <strong>{{ cert.course_title }}</strong>
              <div class="small text-muted">{{ cert.issued_at }} · {{ cert.certificate_code }}</div>
            </div>
            <a class="btn btn-sm btn-success" href="{{ cert.verify }}">{{ text_view }}</a>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>{{ text_none }}</p>
    {% endif %}
  </section>
</div>
