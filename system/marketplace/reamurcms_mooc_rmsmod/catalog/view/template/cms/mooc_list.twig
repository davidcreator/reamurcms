<h1>{{ heading_title }}</h1>
{% if courses %}
  <div class="course-list">
    {% for course in courses %}
      <article class="course-card">
        <h2><a href="{{ course.href }}">{{ course.title }}</a></h2>
        {% if course.subtitle %}<p>{{ course.subtitle }}</p>{% endif %}
        <p>{{ text_duration }}: {{ course.duration_minutes }} min{% if course.is_free %} · {{ text_free }}{% else %} · {{ text_price }} {{ course.price }}{% endif %}</p>
      </article>
    {% endfor %}
  </div>
{% else %}
  <p>{{ text_no_results }}</p>
{% endif %}
