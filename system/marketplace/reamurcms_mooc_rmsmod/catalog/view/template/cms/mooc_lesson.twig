<article class="lesson">
  <a href="{{ course_link }}" class="back">{{ text_back_to_course }}</a>
  <h1>{{ lesson.title }}</h1>
  {% if lesson.summary %}<p class="summary">{{ lesson.summary }}</p>{% endif %}

  <div class="lesson-body">
    {% if content.content %}
      {{ content.content|raw }}
    {% elseif lesson.content_type == 'video' and lesson.video_url %}
      <div class="video">
        <iframe src="{{ lesson.video_url }}" frameborder="0" allowfullscreen></iframe>
      </div>
    {% elseif lesson.external_url %}
      <p><a href="{{ lesson.external_url }}" target="_blank" rel="noopener">{{ lesson.external_url }}</a></p>
    {% else %}
      <p>{{ text_no_lessons }}</p>
    {% endif %}
  </div>

  {% if content.resources or content.attachment %}
    <section class="resources">
      <h3>{{ text_resources }}</h3>
      {% if content.resources %}<p>{{ content.resources|raw }}</p>{% endif %}
      {% if content.attachment %}
        <a class="btn btn-outline-primary" href="{{ content.attachment }}">{{ text_download }}</a>
      {% endif %}
      {% if lesson.external_url %}
        <p><a href="{{ lesson.external_url }}" target="_blank" rel="noopener">{{ lesson.external_url }}</a></p>
      {% endif %}
    </section>
  {% endif %}

  {% if lesson.min_seconds and lesson.min_seconds > 0 %}
    <p class="mt-3"><small>Tempo mÃ­nimo: {{ lesson.min_seconds }}s{% if lesson.auto_complete %} Â· conclusÃ£o automÃ¡tica{% endif %}</small></p>
  {% elseif lesson.auto_complete %}
    <p class="mt-3"><small>ConclusÃ£o automÃ¡tica ao acessar.</small></p>
  {% endif %}

  <section class="mt-4">
    <h3>{{ text_comments }}</h3>
    {% if comments %}
      <ul class="list-group mb-3">
        {% for c in comments %}
          <li class="list-group-item">
            <div class="fw-bold">{{ c.firstname }} {{ c.lastname }}</div>
            <div>{{ c.body }}</div>
            <div class="small text-muted">{{ c.created_at }}</div>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>{{ text_no_results }}</p>
    {% endif %}

    {% if customer_logged %}
      <form method="post" action="{{ comment_action }}">
        <input type="hidden" name="lesson_id" value="{{ lesson.lesson_id }}">
        <input type="hidden" name="course_id" value="{{ lesson.course_id }}">
        <div class="mb-2">
          <textarea name="body" rows="3" class="form-control" placeholder="{{ text_add_comment }}"></textarea>
        </div>
        <button class="btn btn-primary" type="submit">{{ text_comment }}</button>
      </form>
    {% else %}
      <p><a href="{{ course_link }}">{{ text_requires_login }}</a></p>
    {% endif %}
  </section>
</article>

