{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <a href="{{ add }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i> {{ text_add }}</a>
        <button type="submit" form="form-lesson" formaction="{{ delete }}" class="btn btn-danger" onclick="return confirm('Delete selected?');"><i class="fa-regular fa-trash-can"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    {% if success %}
      <div class="alert alert-success">{{ success }}</div>
    {% endif %}
    <div class="card mb-3">
      <div class="card-body">
        <form method="get" class="row g-3">
          <input type="hidden" name="route" value="cms/mooc_lesson">
          <input type="hidden" name="user_token" value="{{ user_token }}">
          <div class="col-md-6">
            <label class="form-label">{{ entry_course }}</label>
            <select name="course_id" class="form-select" onchange="this.form.submit()">
              <option value="0">-- All --</option>
              {% for course in courses %}
                <option value="{{ course.course_id }}" {% if course.course_id == filter_course_id %}selected{% endif %}>{{ course.title }}</option>
              {% endfor %}
            </select>
          </div>
        </form>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-list"></i> {{ text_list }}</div>
      <div class="card-body">
        <form id="form-lesson" method="post">
          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead>
                <tr>
                  <td style="width:1%;" class="text-center"><input type="checkbox" onclick="$('input[name*=\\'selected\\']').prop('checked', this.checked);" /></td>
                  <td>{{ column_course }}</td>
                  <td>{{ column_title }}</td>
                  <td>{{ column_type }}</td>
                  <td>{{ column_status }}</td>
                  <td>{{ column_sort }}</td>
                  <td class="text-end">{{ column_action }}</td>
                </tr>
              </thead>
              <tbody>
                {% if lessons %}
                  {% for lesson in lessons %}
                    <tr>
                      <td class="text-center"><input type="checkbox" name="selected[]" value="{{ lesson.lesson_id }}"></td>
                      <td>{{ lesson.course_title }}</td>
                      <td>{{ lesson.title }}</td>
                      <td>{{ lesson.content_type }}</td>
                      <td>{{ lesson.status ? 'Enabled' : 'Disabled' }}</td>
                      <td>{{ lesson.sort_order }}</td>
                      <td class="text-end"><a href="{{ lesson.edit }}" class="btn btn-primary btn-sm"><i class="fa-solid fa-pencil"></i></a></td>
                    </tr>
                  {% endfor %}
                {% else %}
                  <tr>
                    <td class="text-center" colspan="7">{{ text_no_results }}</td>
                  </tr>
                {% endif %}
              </tbody>
            </table>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
