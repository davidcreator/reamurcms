{{ header }}
{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a href="{{ add }}" class="btn btn-primary"><i class="fa fa-plus"></i> {{ text_add }}</a>
        <button type="submit" form="form-course" formaction="{{ approve }}" class="btn btn-success"><i class="fa fa-check"></i> {{ button_approve }}</button>
        <button type="submit" form="form-course" formaction="{{ delete }}" class="btn btn-danger" onclick="return confirm('Delete selected?');"><i class="fa fa-trash"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if success %}
      <div class="alert alert-success">{{ success }}</div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading"><h3 class="panel-title"><i class="fa fa-list"></i> {{ text_list }}</h3></div>
      <div class="panel-body">
        <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-course">
          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead>
                <tr>
                  <td style="width:1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\\'selected\\']').prop('checked', this.checked);" /></td>
                  <td>{{ column_title }}</td>
                  <td>{{ column_category }}</td>
                  <td>{{ column_instructor }}</td>
                  <td>{{ column_level }}</td>
                  <td>{{ column_status }}</td>
                  <td>{{ column_date }}</td>
                  <td class="text-right">{{ column_action }}</td>
                </tr>
              </thead>
              <tbody>
                {% if courses %}
                  {% for course in courses %}
                    <tr>
                      <td class="text-center"><input type="checkbox" name="selected[]" value="{{ course.course_id }}" /></td>
                      <td>{{ course.title }}</td>
                      <td>{{ course.categories }}</td>
                      <td>{{ course.instructors }}</td>
                      <td>{{ course.level }}</td>
                      <td>
                        {% if course.status == 'published' %}
                          <span class="badge bg-success">{{ text_published }}</span>
                        {% elseif course.status == 'draft' %}
                          <span class="badge bg-secondary">{{ text_draft }}</span>
                        {% else %}
                          {{ course.status }}
                        {% endif %}
                      </td>
                      <td>{{ course.date_added }}</td>
                      <td class="text-right">
                        <a href="{{ course.edit }}" class="btn btn-primary btn-sm"><i class="fa fa-pencil"></i></a>
                      </td>
                    </tr>
                  {% endfor %}
                {% else %}
                  <tr><td colspan="8" class="text-center">{{ text_no_results }}</td></tr>
                {% endif %}
              </tbody>
            </table>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
