{{ header }}
{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-post" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
        <a href="{{ cancel }}" class="btn btn-default"><i class="fa fa-reply"></i> {{ button_cancel }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if errors.warning %}
      <div class="alert alert-danger">{{ errors.warning }}</div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading"><h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_form }}</h3></div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-post" class="form-horizontal">
          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-title">{{ entry_title }}</label>
            <div class="col-sm-10">
              <input type="text" name="title" value="{{ post.title }}" id="input-title" class="form-control" />
              {% if errors.title %}<div class="text-danger">{{ errors.title }}</div>{% endif %}
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-slug">{{ entry_slug }}</label>
            <div class="col-sm-10">
              <input type="text" name="slug" value="{{ post.slug }}" id="input-slug" class="form-control" />
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="status" id="input-status" class="form-control">
                <option value="draft" {{ post.status == 'draft' ? 'selected' : '' }}>{{ text_draft }}</option>
                <option value="published" {{ post.status == 'published' ? 'selected' : '' }}>{{ text_published }}</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-excerpt">{{ entry_excerpt }}</label>
            <div class="col-sm-10">
              <textarea name="excerpt" id="input-excerpt" rows="3" class="form-control">{{ post.excerpt }}</textarea>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-featured">{{ entry_featured_image }}</label>
            <div class="col-sm-10">
              <div class="d-flex gap-3 align-items-center">
                <a href="" id="thumb-image" data-rms-toggle="image" data-rms-target="#input-image" data-rms-thumb="#thumb-image" class="img-thumbnail">
                  <img src="{{ thumb }}" alt="" title="" data-placeholder="{{ placeholder }}" />
                </a>
                <div class="btn-group-vertical" role="group">
                  <button type="button" data-rms-toggle="image" data-rms-target="#input-image" data-rms-thumb="#thumb-image" class="btn btn-primary btn-sm"><i class="fa-solid fa-pencil"></i> {{ button_edit }}</button>
                  <button type="button" data-rms-toggle="clear" data-rms-target="#input-image" data-rms-thumb="#thumb-image" class="btn btn-warning btn-sm"><i class="fa-regular fa-trash-can"></i> {{ button_clear }}</button>
                </div>
              </div>
              <input type="hidden" name="featured_image" value="{{ post.featured_image }}" id="input-image"/>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-content">{{ entry_content }}</label>
            <div class="col-sm-10">
              <textarea name="content" id="input-content" rows="12" data-rms-toggle="ckeditor" data-lang="{{ ckeditor }}" class="form-control">{{ post.content }}</textarea>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-published">{{ entry_published_at }}</label>
            <div class="col-sm-10">
              <input type="datetime-local" name="published_at" value="{{ post.published_at }}" id="input-published" class="form-control"/>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-meta-title">{{ entry_meta_title }}</label>
            <div class="col-sm-10">
              <input type="text" name="meta_title" value="{{ post.meta_title }}" id="input-meta-title" class="form-control"/>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-meta-description">{{ entry_meta_description }}</label>
            <div class="col-sm-10">
              <textarea name="meta_description" id="input-meta-description" rows="3" class="form-control">{{ post.meta_description }}</textarea>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-meta-keyword">{{ entry_meta_keyword }}</label>
            <div class="col-sm-10">
              <input type="text" name="meta_keyword" value="{{ post.meta_keyword }}" id="input-meta-keyword" class="form-control"/>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript">
  $('textarea[data-rms-toggle=\'ckeditor\']').ckeditor({
    language: '{{ ckeditor }}'
  });
</script>
{{ footer }}
