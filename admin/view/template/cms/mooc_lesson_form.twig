{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-lesson" class="btn btn-primary"><i class="fa-solid fa-save"></i> {{ button_save }}</button>
        <a href="{{ cancel }}" class="btn btn-light"><i class="fa-solid fa-reply"></i> {{ button_cancel }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    {% if errors.warning %}<div class="alert alert-danger">{{ errors.warning }}</div>{% endif %}
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-book"></i> {{ text_form }}</div>
      <div class="card-body">
        <form id="form-lesson" method="post" action="{{ action }}">
          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">{{ entry_course }}</label>
              <select name="course_id" class="form-select">
                <option value="">{{ text_no_results }}</option>
                {% for course in courses %}
                  <option value="{{ course.course_id }}" {% if course.course_id == lesson.course_id %}selected{% endif %}>{{ course.title }}</option>
                {% endfor %}
              </select>
              {% if errors.course_id %}<div class="text-danger">{{ errors.course_id }}</div>{% endif %}
            </div>
            <div class="col-md-6">
              <label class="form-label">{{ entry_sort_order }}</label>
              <input type="number" name="sort_order" value="{{ lesson.sort_order }}" class="form-control">
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-8">
              <label class="form-label">{{ entry_title }}</label>
              <input type="text" name="title" value="{{ lesson.title }}" class="form-control">
              {% if errors.title %}<div class="text-danger">{{ errors.title }}</div>{% endif %}
            </div>
            <div class="col-md-4">
              <label class="form-label">{{ entry_slug }}</label>
              <input type="text" name="slug" value="{{ lesson.slug }}" class="form-control">
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">{{ entry_summary }}</label>
            <textarea name="summary" rows="3" class="form-control">{{ lesson.summary }}</textarea>
          </div>

          <div class="row mb-3">
            <div class="col-md-4">
              <label class="form-label">{{ entry_content_type }}</label>
              <select name="content_type" class="form-select">
                <option value="video" {% if lesson.content_type == 'video' %}selected{% endif %}>{{ text_video }}</option>
                <option value="article" {% if lesson.content_type == 'article' %}selected{% endif %}>{{ text_article }}</option>
                <option value="quiz" {% if lesson.content_type == 'quiz' %}selected{% endif %}>{{ text_quiz }}</option>
                <option value="live" {% if lesson.content_type == 'live' %}selected{% endif %}>{{ text_live }}</option>
                <option value="slides" {% if lesson.content_type == 'slides' %}selected{% endif %}>{{ text_slides }}</option>
                <option value="pdf" {% if lesson.content_type == 'pdf' %}selected{% endif %}>{{ text_pdf }}</option>
                <option value="link" {% if lesson.content_type == 'link' %}selected{% endif %}>{{ text_link }}</option>
                <option value="download" {% if lesson.content_type == 'download' %}selected{% endif %}>{{ text_download }}</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">{{ entry_video_url }}</label>
              <input type="text" name="video_url" value="{{ lesson.video_url }}" class="form-control" placeholder="https://...">
            </div>
            <div class="col-md-4">
              <label class="form-label">{{ entry_external_url }}</label>
              <input type="text" name="external_url" value="{{ lesson.external_url }}" class="form-control" placeholder="https://...">
            </div>
            <div class="col-md-2">
              <label class="form-label">{{ entry_duration }}</label>
              <input type="number" name="duration_minutes" value="{{ lesson.duration_minutes }}" class="form-control" min="0">
            </div>
            <div class="col-md-2">
              <label class="form-label">{{ entry_min_time }}</label>
              <input type="number" name="min_seconds" value="{{ lesson.min_seconds }}" class="form-control" min="0">
            </div>
            <div class="col-md-2">
              <label class="form-label">{{ entry_status }}</label>
              <select name="status" class="form-select">
                <option value="1" {% if lesson.status %}selected{% endif %}>Enabled</option>
                <option value="0" {% if not lesson.status %}selected{% endif %}>Disabled</option>
              </select>
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">{{ entry_auto_complete }}</label>
              <select name="auto_complete" class="form-select">
                <option value="1" {% if lesson.auto_complete %}selected{% endif %}>Yes</option>
                <option value="0" {% if not lesson.auto_complete %}selected{% endif %}>No</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">{{ entry_comments }}</label>
              <select name="comments_enabled" class="form-select">
                <option value="1" {% if lesson.comments_enabled %}selected{% endif %}>Yes</option>
                <option value="0" {% if not lesson.comments_enabled %}selected{% endif %}>No</option>
              </select>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">{{ entry_release_at }}</label>
            <input type="text" name="release_at" value="{{ lesson.release_at }}" class="form-control" placeholder="YYYY-MM-DD HH:MM:SS">
          </div>

          <div class="mb-3">
            <label class="form-label">{{ entry_content }}</label>
            <textarea name="content" rows="6" class="form-control">{{ lesson.content }}</textarea>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">{{ entry_resources }}</label>
              <textarea name="resources" rows="3" class="form-control">{{ lesson.resources }}</textarea>
            </div>
            <div class="col-md-6">
              <label class="form-label">{{ entry_attachment }}</label>
              <input type="text" name="attachment" value="{{ lesson.attachment }}" class="form-control" placeholder="https://...">
            </div>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
