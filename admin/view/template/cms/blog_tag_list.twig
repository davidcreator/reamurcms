{{ header }}
{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-tag" formaction="{{ delete }}" class="btn btn-danger"><i class="fa fa-trash"></i> {{ button_delete }}</button>
        <a href="{{ add }}" class="btn btn-primary"><i class="fa fa-plus"></i> {{ text_add }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if success %}
      <div class="alert alert-success">{{ success }}</div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading"><h3 class="panel-title"><i class="fa fa-tags"></i> {{ heading_title }}</h3></div>
      <div class="panel-body">
        <form action="" method="get" class="form-inline mb-2">
          <input type="hidden" name="route" value="cms/blog_tag">
          <input type="hidden" name="user_token" value="{{ user_token }}">
          <div class="form-group">
            <select name="status" class="form-control">
              <option value="">{{ text_all }}</option>
              <option value="1" {{ filter_status is same as('1') ? 'selected' : '' }}>{{ text_enabled }}</option>
              <option value="0" {{ filter_status is same as('0') ? 'selected' : '' }}>{{ text_disabled }}</option>
            </select>
          </div>
          <div class="form-group">
            <input type="text" name="q" value="{{ filter_q }}" class="form-control" placeholder="search">
          </div>
          <button class="btn btn-primary" type="submit"><i class="fa fa-filter"></i></button>
        </form>

        <form action="" method="post" id="form-tag">
          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead>
                <tr>
                  <td style="width:1px" class="text-center"><input type="checkbox" onclick="$('input[name*=\\'selected\\']').prop('checked', this.checked);"/></td>
                  <td>{{ column_title }}</td>
                  <td>{{ entry_slug }}</td>
                  <td>{{ column_status }}</td>
                  <td>{{ entry_sort_order }}</td>
                  <td>{{ column_date }}</td>
                  <td class="text-right">{{ column_action }}</td>
                </tr>
              </thead>
              <tbody>
              {% if tags %}
                {% for tag in tags %}
                  <tr>
                    <td class="text-center"><input type="checkbox" name="selected[]" value="{{ tag.tag_id }}"/></td>
                    <td>{{ tag.name }}</td>
                    <td>{{ tag.slug }}</td>
                    <td>{{ tag.status ? text_enabled : text_disabled }}</td>
                    <td>{{ tag.sort_order }}</td>
                    <td>{{ tag.date_modified }}</td>
                    <td class="text-right"><a href="{{ tag.edit }}" class="btn btn-primary"><i class="fa fa-pencil"></i></a></td>
                  </tr>
                {% endfor %}
              {% else %}
                <tr><td class="text-center" colspan="7">{{ text_no_results }}</td></tr>
              {% endif %}
              </tbody>
            </table>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
