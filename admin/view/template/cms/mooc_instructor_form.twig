{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-instructor" class="btn btn-primary"><i class="fa-solid fa-save"></i> {{ button_save }}</button>
        <a href="{{ cancel }}" class="btn btn-light"><i class="fa-solid fa-reply"></i> {{ button_cancel }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    {% if errors.warning %}<div class="alert alert-danger">{{ errors.warning }}</div>{% endif %}
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-user"></i> {{ text_form }}</div>
      <div class="card-body">
        <form id="form-instructor" method="post" action="{{ action }}">
          <div class="mb-3">
            <label class="form-label">{{ entry_name }}</label>
            <input type="text" name="name" value="{{ instructor.name }}" class="form-control">
            {% if errors.name %}<div class="text-danger">{{ errors.name }}</div>{% endif %}
          </div>
          <div class="mb-3">
            <label class="form-label">{{ entry_headline }}</label>
            <input type="text" name="headline" value="{{ instructor.headline }}" class="form-control">
          </div>
          <div class="mb-3">
            <label class="form-label">{{ entry_bio }}</label>
            <textarea name="bio" rows="4" class="form-control">{{ instructor.bio }}</textarea>
          </div>
          <div class="mb-3">
            <label class="form-label">{{ entry_photo }}</label>
            <input type="text" name="photo" value="{{ instructor.photo }}" class="form-control" placeholder="https://...">
          </div>
          <div class="row">
            <div class="col">
              <label class="form-label">{{ entry_linkedin }}</label>
              <input type="text" name="linkedin" value="{{ instructor.linkedin }}" class="form-control">
            </div>
            <div class="col">
              <label class="form-label">{{ entry_twitter }}</label>
              <input type="text" name="twitter" value="{{ instructor.twitter }}" class="form-control">
            </div>
            <div class="col">
              <label class="form-label">{{ entry_website }}</label>
              <input type="text" name="website" value="{{ instructor.website }}" class="form-control">
            </div>
          </div>
          <div class="mt-3">
            <label class="form-label">{{ entry_user_id }}</label>
            <input type="number" name="user_id" value="{{ instructor.user_id }}" class="form-control">
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
