{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a href="{{ add }}" class="btn btn-primary"><i class="fa fa-plus"></i> {{ text_add }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if success %}
      <div class="alert alert-success"><i class="fa fa-check-circle"></i> {{ success }}</div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-file-code-o"></i> {{ heading_title }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-template">
          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead>
                <tr>
                  <td style="width: 1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\\'selected\\']').prop('checked', this.checked);" /></td>
                  <td>{{ column_template }}</td>
                  <td>{{ column_status }}</td>
                  <td>{{ column_date }}</td>
                  <td class="text-right">{{ column_action }}</td>
                </tr>
              </thead>
              <tbody>
                {% if templates %}
                  {% for t in templates %}
                    <tr>
                      <td class="text-center"><input type="checkbox" name="selected[]" value="{{ t.template_id }}" /></td>
                      <td>{{ t.name }} <span class="label label-default">{{ t.code }}</span></td>
                      <td>{{ t.status ? 'Enabled' : 'Disabled' }}</td>
                      <td>{{ t.date_modified }}</td>
                      <td class="text-right"><a href="{{ t.edit }}" class="btn btn-primary btn-sm"><i class="fa fa-pencil"></i></a></td>
                    </tr>
                  {% endfor %}
                {% else %}
                  <tr><td class="text-center" colspan="5">{{ text_no_results }}</td></tr>
                {% endif %}
              </tbody>
            </table>
          </div>
          <div class="row">
            <div class="col-sm-6 text-left"></div>
            <div class="col-sm-6 text-right"></div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
