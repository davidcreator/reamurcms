{{ header }}
{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    <div class="panel panel-default">
      <div class="panel-heading"><h3 class="panel-title"><i class="fa fa-comments"></i> {{ heading_title }}</h3></div>
      <div class="panel-body">
        <form action="" method="get" class="form-inline mb-2">
          <input type="hidden" name="route" value="cms/blog_comment">
          <input type="hidden" name="user_token" value="{{ user_token }}">
          <div class="form-group">
            <select name="status" class="form-control">
              <option value="">{{ text_all }}</option>
              <option value="1" {{ filter_status is same as('1') ? 'selected' : '' }}>{{ text_enabled }}</option>
              <option value="0" {{ filter_status is same as('0') ? 'selected' : '' }}>{{ text_pending }}</option>
              <option value="2" {{ filter_status is same as('2') ? 'selected' : '' }}>{{ text_spam }}</option>
              <option value="3" {{ filter_status is same as('3') ? 'selected' : '' }}>{{ text_blocked }}</option>
            </select>
          </div>
          <div class="form-group">
            <input type="text" name="q" value="{{ filter_q }}" class="form-control" placeholder="search">
          </div>
          <button class="btn btn-primary" type="submit"><i class="fa fa-filter"></i></button>
        </form>

        <form action="" method="post" id="form-comment">
          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead>
                <tr>
                  <td style="width:1px" class="text-center"><input type="checkbox" onclick="$('input[name*=\\'selected\\']').prop('checked', this.checked);" /></td>
                  <td>Post</td>
                  <td>Author</td>
                  <td>Email</td>
                  <td>Status</td>
                  <td>Content</td>
                  <td>Date</td>
                </tr>
              </thead>
              <tbody>
              {% if comments %}
                {% for c in comments %}
                  <tr>
                    <td class="text-center"><input type="checkbox" name="selected[]" value="{{ c.comment_id }}"/></td>
                    <td><a href="{{ c.post_link }}">{{ c.post_title }}</a></td>
                    <td>{{ c.author }}</td>
                    <td>{{ c.email }}</td>
                    <td>{{ c.status_label }}</td>
                    <td>{{ c.content }}</td>
                    <td>{{ c.date_added }}</td>
                  </tr>
                {% endfor %}
              {% else %}
                <tr><td class="text-center" colspan="7">{{ text_no_results }}</td></tr>
              {% endif %}
              </tbody>
            </table>
          </div>
          <div class="mt-3 d-flex flex-wrap gap-2">
            <button type="submit" formaction="{{ approve }}" class="btn btn-success"><i class="fa fa-check"></i> {{ button_approve }}</button>
            <button type="submit" formaction="{{ disapprove }}" class="btn btn-warning"><i class="fa fa-ban"></i> {{ button_disapprove }}</button>
            <button type="submit" formaction="{{ spam }}" class="btn btn-danger"><i class="fa fa-exclamation-triangle"></i> {{ button_spam }}</button>
            <button type="submit" formaction="{{ block }}" class="btn btn-dark"><i class="fa fa-user-slash"></i> {{ button_block }}</button>
            <button type="submit" formaction="{{ delete }}" class="btn btn-default"><i class="fa fa-trash"></i> {{ button_delete }}</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
