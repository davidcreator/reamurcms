{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-split" class="btn btn-primary"><i class="fa-solid fa-save"></i> {{ button_save }}</button>
        <a href="{{ cancel }}" class="btn btn-light"><i class="fa-solid fa-reply"></i> {{ button_cancel }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}<div class="alert alert-danger">{{ error_warning }}</div>{% endif %}
    <div class="card">
      <div class="card-header">{{ text_edit }}</div>
      <div class="card-body">
        <form id="form-split" method="post" action="{{ action }}">
          <div class="mb-3">
            <label class="form-label">{{ entry_platform_fee }}</label>
            <input type="number" step="0.1" min="0" max="100" name="payment_platform_fee" value="{{ payment_platform_fee|default(20) }}" class="form-control">
          </div>
          <div class="mb-3">
            <label class="form-label">{{ entry_stripe_secret }}</label>
            <input type="text" name="payment_stripe_secret" value="{{ payment_stripe_secret }}" class="form-control">
          </div>
          <div class="mb-3">
            <label class="form-label">{{ entry_stripe_public }}</label>
            <input type="text" name="payment_stripe_public" value="{{ payment_stripe_public }}" class="form-control">
          </div>
          <div class="mb-3">
            <label class="form-label">{{ entry_mp_token }}</label>
            <input type="text" name="payment_mp_access_token" value="{{ payment_mp_access_token }}" class="form-control">
          </div>
          <div class="mb-3">
            <label class="form-label">{{ entry_default_stripe }}</label>
            <input type="text" name="payment_default_stripe_account" value="{{ payment_default_stripe_account }}" class="form-control" placeholder="acct_... (destino padrão)">
          </div>
          <div class="mb-3">
            <label class="form-label">{{ entry_default_mp }}</label>
            <input type="text" name="payment_default_mp_user" value="{{ payment_default_mp_user }}" class="form-control" placeholder="ID MP padrão">
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
