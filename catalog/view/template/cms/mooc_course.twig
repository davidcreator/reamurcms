<article class="course">
  {% if success %}
    <div class="alert alert-success">{{ success }}</div>
  {% endif %}

  <h1>{{ course.title }}</h1>
  {% if course.featured_image %}<img src="{{ course.featured_image }}" alt="{{ course.title }}" class="img-fluid mb-3">{% endif %}
  {% if course.subtitle %}<h3>{{ course.subtitle }}</h3>{% endif %}
  <p>{{ text_level }}: {{ course.level }} - {{ text_duration }}: {{ course.duration_minutes }} min</p>
  {% if course.instructors %}<p>{{ text_instructor }}: {{ course.instructors }}</p>{% endif %}
  {% if course.categories %}<p>{{ text_categories }}: {{ course.categories }}</p>{% endif %}

  <div class="description">
    {{ course.description|raw }}
  </div>

  {% if not course.is_free %}
    <p class="price">{{ text_price }} {{ course.price }}</p>
  {% else %}
    <p class="price">{{ text_free }}</p>
  {% endif %}

  <div class="course-actions">
    {% if customer_logged %}
      {% if is_enrolled %}
        <span class="badge bg-success">{{ text_enrolled }}</span>
      <a class="btn btn-primary" href="#lessons">{{ text_continue_course }}</a>
    {% else %}
      <form action="{{ enroll_action }}" method="post">
        <button type="submit" class="btn btn-primary">{{ text_enroll }}</button>
      </form>
    {% endif %}
  {% else %}
    <a class="btn btn-primary" href="{{ login_link }}">{{ text_requires_login }}</a>
  {% endif %}
  </div>

  {% if is_enrolled %}
    <section class="mt-3">
      <p>{{ text_progress }}: {{ progress }}%{% if final_score is not null %} · {{ text_final_score }}: {{ final_score|number_format(1) }}{% endif %} · {{ text_time_spent }}: {{ (time_spent_seconds/60)|number_format(1) }} min</p>
      <div class="progress">
        <div class="progress-bar bg-success" style="width: {{ progress }}%"></div>
      </div>
      {% if progress == 100 and certificate_link %}
        <a class="btn btn-success mt-2" href="{{ certificate_link }}">{{ text_certificate }}</a>
      {% endif %}
    </section>
  {% endif %}

  {% if is_enrolled %}
    <section id="lessons" class="mt-4">
      <h3>{{ text_lessons }}</h3>
      {% if lessons %}
        <ol class="lesson-list">
          {% for lesson in lessons %}
            <li>
              <a href="{{ lesson.href }}">{{ lesson.title }}</a>
              {% set status = lesson.progress_status %}
              {% if status == 'completed' %}<span class="badge bg-success">✔</span>
              {% elseif status == 'in_progress' %}<span class="badge bg-warning text-dark">⏳</span>
              {% else %}<span class="badge bg-secondary">○</span>{% endif %}
              <div class="small text-muted">
                {% if lesson.duration_minutes %}{{ text_duration }}: {{ lesson.duration_minutes }} min{% endif %}
                {% if lesson.time_spent_seconds %} · {{ text_time_spent }}: {{ (lesson.time_spent_seconds/60)|number_format(1) }} min{% endif %}
                {% if lesson.score is not null %} · {{ text_final_score }}: {{ lesson.score|number_format(1) }}{% endif %}
              </div>
            </li>
          {% endfor %}
        </ol>
      {% else %}
        <p>{{ text_no_lessons }}</p>
      {% endif %}
    </section>
  {% endif %}
</article>
